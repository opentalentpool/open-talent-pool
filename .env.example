# Copy this file to `.env` and replace every placeholder before running outside
# local development. Never commit `.env`, `.env.local`, or real credentials.

# Frontend
VITE_API_URL=
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
APP_BASE_URL=http://localhost:8080
TRUSTED_ORIGINS=http://localhost:8080
WEB_PUBLISHED_PORT=8080
POSTGRES_PUBLISHED_PORT=5432
MAILPIT_SMTP_PUBLISHED_PORT=1025
MAILPIT_WEB_PUBLISHED_PORT=8025

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=otp
POSTGRES_USER=otp
POSTGRES_PASSWORD=change_me

# Auth, captcha, and cookies
AUTH_CODE_PEPPER=dev-only-auth-pepper
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TRUST_PROXY=false
COOKIE_DOMAIN=
COOKIE_SECURE=false
AUTH_SESSION_IDLE_HOURS=24
AUTH_SESSION_MAX_DAYS=7
INTERNAL_OPERATIONS_ADMIN_EMAIL=internal-admin@opentalentpool.local
INTERNAL_ACCOUNT_EMAIL_DOMAIN=opentalentpool.local

# Alerts and async email queue
ALERTS_DISPATCH_INTERVAL_SECONDS=900
REDIS_USERNAME=otp_mail
REDIS_PASSWORD=change_me
MAIL_QUEUE_PREFIX=otp:mail
MAIL_WORKER_CONCURRENCY=4
MAIL_OUTBOX_POLL_INTERVAL_MS=5000
MAIL_OUTBOX_BATCH_SIZE=25
MAIL_RETRY_MAX_ATTEMPTS=5
MAIL_RETRY_BASE_DELAY_MS=60000

# SMTP
# Default dev SMTP uses Mailpit, started automatically by `pnpm run dev`.
# Inbox: http://localhost:8025
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_AUTH_REQUIRED=false
SMTP_FROM=OpenTalentPool <dev@opentalentpool.local>

# Optional personal Gmail SMTP for development.
# Use a Gmail App Password, not your regular account password.
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your.address@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_SECURE=true
# SMTP_AUTH_REQUIRED=true
# SMTP_FROM=OpenTalentPool <your.address@gmail.com>

# Runtime guards
DEBUG=false
OTP_IN_MEMORY_DB=false
ENABLE_TEST_ROUTES=false
