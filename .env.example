# Copy this file to `.env` and replace every placeholder before running outside
# local development. Never commit `.env`, `.env.local`, or real credentials.

# Frontend
VITE_API_URL=
VITE_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
APP_BASE_URL=http://localhost:8080
TRUSTED_ORIGINS=http://localhost:8080
WEB_PUBLISHED_PORT=8080
POSTGRES_PUBLISHED_PORT=5432

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=otp
POSTGRES_USER=otp
POSTGRES_PASSWORD=replace-with-postgres-password

# Auth, captcha, and cookies
AUTH_CODE_PEPPER=replace-with-long-random-auth-pepper
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key
TRUST_PROXY=false
COOKIE_DOMAIN=
COOKIE_SECURE=false
AUTH_SESSION_IDLE_HOURS=24
AUTH_SESSION_MAX_DAYS=7

# Alerts and async email queue
ALERTS_DISPATCH_INTERVAL_SECONDS=900
REDIS_USERNAME=otp_mail
REDIS_PASSWORD=replace-with-redis-password
MAIL_QUEUE_PREFIX=otp:mail
MAIL_WORKER_CONCURRENCY=4
MAIL_OUTBOX_POLL_INTERVAL_MS=5000
MAIL_OUTBOX_BATCH_SIZE=25
MAIL_RETRY_MAX_ATTEMPTS=5
MAIL_RETRY_BASE_DELAY_MS=60000

# SMTP
SMTP_SERVER=replace-with-smtp-host
SMTP_PORT=465
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_SECURE=true
SMTP_FROM=OpenTalentPool <replace-with-sender-email>

# Runtime guards
DEBUG=false
OTP_IN_MEMORY_DB=false
ENABLE_TEST_ROUTES=false
